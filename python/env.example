# InstantMBTA Environment Configuration
# Copy this file to .env and fill in your values

# Required: Your MBTA API key from https://api-v3.mbta.com/
MBTA_API_KEY=your_api_key_here

# Optional: API timeout in seconds (default: 30)
MBTA_API_TIMEOUT=30

# Optional: Maximum retry attempts (default: 5)
MBTA_MAX_RETRIES=5

# Optional: Base retry delay in seconds (default: 5)
MBTA_RETRY_DELAY=5

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MBTA_LOG_LEVEL=INFO

# Testing: Set to 'true' to use test API key (automatically set by test runner)
TESTING=false 